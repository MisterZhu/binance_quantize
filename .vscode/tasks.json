{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/streamlit",
      "args": [
        "run",
        "app.py",
        "--server.address",
        "127.0.0.1",
        "--server.port",
        "8501",
        "--browser.gatherUsageStats",
        "false",
        "--server.headless",
        "true"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Bot Once",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["bot_runner.py", "--once"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Bot Loop",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["bot_runner.py", "--interval", "60"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
